<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Smoke Suite" parallel="methods" thread-count="2">

    <test name="Smoke Tests">

        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <classes>
            <class name="tests.LoginTests"/>
            <class name="tests.ClientsTests"/>
        </classes>

    </test>

</suite>